<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
  .profile-hub-v106{display:grid;grid-template-columns:1.2fr .8fr;gap:20px;margin:20px 0 28px}.profile-card-v106{position:relative;overflow:hidden;padding:24px;border-radius:30px;border:1px solid rgba(239,68,68,.18);background:radial-gradient(circle at 10% 15%,rgba(239,68,68,.15),transparent 34%),linear-gradient(145deg,rgba(10,16,26,.98),rgba(4,7,12,.98));box-shadow:0 28px 80px rgba(0,0,0,.32)}.profile-grid-v106{display:grid;grid-template-columns:190px 1fr;gap:24px;align-items:start}.profile-avatar-v106{position:relative}.profile-avatar-v106 img{display:block;width:190px;height:190px;object-fit:contain;padding:8px;border-radius:34px;border:2px solid rgba(239,68,68,.38);background:radial-gradient(circle at 50% 45%,#341010 0%,#0a0f18 58%,#050913 100%);box-shadow:0 18px 48px rgba(0,0,0,.38),0 0 35px rgba(239,68,68,.12)}.profile-avatar-v106::after{content:'RAID-Z';position:absolute;left:12px;right:12px;bottom:34px;padding:6px 8px;border-radius:10px;background:rgba(3,7,14,.78);font-size:.72rem;font-weight:900;letter-spacing:.16em;text-align:center;color:#fff}.profile-avatar-v106 small{display:block;margin-top:10px;color:#9fb0c8;text-align:center}.profile-card-v106 h2{margin:0 0 8px;font-size:1.65rem}.profile-card-v106 p{margin:0 0 12px;color:#c5cfdb;line-height:1.55}.profile-form-v106{display:grid;gap:12px}.profile-form-v106 textarea,.profile-form-v106 input{width:100%}.profile-upload-note-v111{padding:10px 12px;border-radius:14px;background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);color:#bbf7d0;font-size:.84rem}.profile-badges-v106{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}.profile-badges-v106 span{padding:8px 12px;border-radius:999px;background:rgba(255,255,255,.06);font-weight:800;font-size:.8rem}.profile-side-v106{display:grid;gap:14px}.profile-side-box-v106{padding:18px;border-radius:22px;background:rgba(255,255,255,.035);border:1px solid rgba(255,255,255,.08)}.profile-side-box-v106 strong{display:block;font-size:1.06rem}.profile-side-box-v106 small{color:#9fb0c8}.profile-side-box-v106 .btn{margin-top:12px} @media (max-width: 900px){.profile-hub-v106{grid-template-columns:1fr}.profile-grid-v106{grid-template-columns:1fr}.profile-avatar-v106 img{width:150px;height:150px;margin:auto}}
</style>

<main class="container wallet-page wallet-page-v33">
  <%- include('partials/alerts') %>

  <section class="wallet-hero wallet-hero-v33 sz-hover-card" aria-label="Carteira do player">
    <div class="wallet-hero-copy-v33">
      <p class="eyebrow">Minhas doações</p>
      <h1>Fazer <span>Doação</span></h1>
      <p>Doe por Pix para manter o servidor online e receba RZ Coins para usar na loja Vanilla, veículos, seguros e kits. O saldo fica salvo na sua conta.</p>
      <div class="wallet-badges wallet-badges-v33">
        <span>⚡ Pix rápido</span>
        <span>R$1 = 1.000 <%= currencyName %></span>
        <span>Entrega no DayZ</span>
      </div>
      <div class="wallet-player-v33">
        <b><%= player.nickname || 'Player' %></b>
        <small>Steam64: <code><%= player.steam64 %></code></small>
      </div>
    </div>

    <div class="wallet-balance-stage-v33">
      <div class="wallet-balance-card-v33">
        <span>Saldo atual</span>
        <strong class="wallet-balance-animated" data-value="<%= player.coins || 0 %>"><%= coins(player.coins) %></strong>
        <small><%= currencyName %></small>
      </div>
      <div class="wallet-coin-stack-v33" aria-hidden="true">
        <i></i><i></i><i></i><i></i><b>RZ</b>
      </div>
    </div>
  </section>

  <section class="profile-hub-v106" id="perfil-player">
    <article class="profile-card-v106">
      <div class="profile-grid-v106">
        <div class="profile-avatar-v106">
          <img src="<%= player.hasAvatar ? ('/player-avatar/' + player.id + '?v=' + (player.updatedAt ? new Date(player.updatedAt).getTime() : Date.now())) : '/images/raidz-profile-default.webp' %>" alt="Avatar do player" onerror="this.onerror=null;this.src='/images/raidz-profile-default.webp'">
          <small>Avatar vinculado ao Steam64</small>
        </div>
        <div>
          <p class="eyebrow">Perfil do player</p>
          <h2>Seu nome e sua foto na loja</h2>
          <p>Essas informações ficam salvas no seu Steam64 e aparecem na aba de clãs, recrutamento e no seu perfil. A imagem de perfil é obrigatória para criar um clã ou enviar uma solicitação de entrada.</p>
          <form method="POST" action="/profile" enctype="multipart/form-data" class="profile-form-v106">
            <label>Nome de exibição
              <input name="nickname" maxlength="100" value="<%= player.nickname || '' %>" placeholder="Seu nick / nome dentro do jogo">
            </label>
            <label>Mensagem curta / bio
              <textarea name="profileBio" rows="3" maxlength="400" placeholder="Ex: builder, PvP, farmer, líder de squad"><%= player.profileBio || '' %></textarea>
            </label>
            <label>Imagem de perfil
              <input type="file" name="avatar" accept="image/png,image/jpeg,image/webp,image/gif" <%= player.hasAvatar ? '' : 'required' %>>
            </label>
            <div class="profile-upload-note-v111"><%= player.hasAvatar ? 'Imagem salva. Para trocar, selecione outra foto e salve novamente.' : 'Envie uma imagem para liberar criação e entrada em clãs.' %> Formatos: PNG, JPG, WEBP ou GIF, até 4 MB.</div>
            <button class="btn primary" type="submit">Salvar perfil</button>
          </form>
        </div>
      </div>
    </article>

    <aside class="profile-card-v106 profile-side-v106">
      <div class="profile-side-box-v106">
        <small>Steam64</small>
        <strong><%= player.steam64 %></strong>
        <div class="profile-badges-v106">
          <% if (membership?.clan) { %><span>🛡 Clã: [<%= membership.clan.tag %>] <%= membership.clan.name %></span><% } else { %><span>🛡 Sem clã</span><% } %>
          <% if (activeOutfit?.outfitTemplate?.name) { %><span>👑 VIP: <%= activeOutfit.outfitTemplate.name %></span><% } else { %><span>👑 Sem traje VIP ativo</span><% } %>
        </div>
      </div>
      <div class="profile-side-box-v106">
        <small>Clãs & recrutamento</small>
        <strong><%= membership?.clan ? 'Seu clã está visível para todos' : 'Procure um clã ou crie o seu' %></strong>
        <p><%= membership?.clan ? 'Você já aparece na aba de clãs com suas informações, avatar e status VIP.' : 'Abra a nova aba de clãs para ver quem está recrutando, mandar formulário ou criar seu próprio clã.' %></p>
        <a class="btn" href="<%= membership?.clan ? '/my-clan' : '/clans' %>"><%= membership?.clan ? 'Abrir painel do meu clã' : 'Ir para Clãs & Recrutamento' %></a>
      </div>
    </aside>
  </section>

  <section class="playtime-reward-alert-v78 wallet-playtime-v78 sz-hover-card" aria-label="Moedas por tempo de jogatina">
    <div class="playtime-reward-icon-v78" aria-hidden="true">⏱</div>
    <div>
      <strong>Também dá para ganhar moedas jogando</strong>
      <p>Seu tempo de jogatina no RAID-Z pode virar moedas no saldo automaticamente. O site não divulga valores nesse aviso.</p>
    </div>
  </section>

  <section class="wallet-buy-panel wallet-buy-panel-v33" id="comprar-moedas">
    <div class="wallet-buy-head wallet-buy-head-v33">
      <div>
        <p class="eyebrow">Doação por Pix</p>
        <h2>Escolha sua doação</h2>
        <p class="muted">Doações rápidas em cards 3D ou valor personalizado. <strong>R$1 = 1.000 <%= currencyName %></strong>.</p>
      </div>
      <div class="wallet-rate-chip wallet-rate-chip-v33"><span>cotação fixa</span><b>1.000 RZ / R$1</b></div>
    </div>

    <section class="card support-code-wallet-card">
      <p class="eyebrow">Apoiar streamer</p>
      <label>Código do streamer opcional
        <input id="streamerSupportCodeWallet" placeholder="Ex: BRENO10" maxlength="32" style="text-transform:uppercase">
      </label>
      <small class="muted">Se preencher, essa doação aparece no painel do streamer e calcula a comissão configurada pelo admin.</small>
    </section>

    <div class="coin-store-layout-v33">
      <div class="coin-pack-grid-v33">
        <% packages.forEach((pack, index) => { %>
          <form method="POST" action="/checkout/<%= pack.id %>" class="coin-pack-v33 sz-hover-card <%= index === 2 ? 'popular' : '' %>" data-coin-checkout>
            <input type="hidden" name="streamerCode" data-support-code-hidden>
            <% if (index === 2) { %><em>Mais escolhido</em><% } %>
            <div class="coin-pack-art-v33"><span>RZ</span></div>
            <div class="coin-pack-content-v33">
              <small>Doação rápida</small>
              <h3><%= pack.name %></h3>
              <strong><%= coins(pack.coins) %> <%= currencyName %></strong>
              <p><%= brl(pack.amountBrl) %></p>
              <% if (pack.bonusText) { %><b><%= pack.bonusText %></b><% } else { %><b>R$1 = 1.000 RZ</b><% } %>
              <button class="btn primary coin-buy-btn-v33" type="submit">Gerar Pix da doação</button>
            </div>
          </form>
        <% }) %>
      </div>

      <form method="POST" action="/checkout-custom" class="wallet-custom-v33 sz-hover-card" id="customCoinsForm" data-coin-checkout>
        <input type="hidden" name="streamerCode" data-support-code-hidden>
        <div class="wallet-custom-top-v33">
          <span>💎</span>
          <div>
            <small>Personalizado</small>
            <h3>Monte sua doação</h3>
          </div>
        </div>
        <div class="wallet-custom-value-v33">
          <strong id="customCoinsValue">10.000 <%= currencyName %></strong>
          <span id="customBrlValue">R$ 10,00</span>
        </div>
        <div class="wallet-custom-controls-v33">
          <label>Quantidade de moedas</label>
          <input type="range" min="1000" max="200000" step="1000" value="10000" id="customCoinsRange">
          <input type="number" min="1000" max="5000000" step="1000" value="10000" name="customCoins" id="customCoinsInput">
        </div>
        <button class="btn primary coin-buy-btn-v33" type="submit">Gerar Pix da doação</button>
      </form>
    </div>
  </section>

  <script>
    (() => {
      const range = document.getElementById('customCoinsRange');
      const input = document.getElementById('customCoinsInput');
      const coinsText = document.getElementById('customCoinsValue');
      const brlText = document.getElementById('customBrlValue');
      if (!range || !input) return;
      const fmtCoins = (n) => new Intl.NumberFormat('pt-BR').format(n);
      const fmtBrl = (n) => new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(n);
      const sync = (value) => {
        let n = Number(value || 0);
        if (!Number.isFinite(n) || n < 1000) n = 1000;
        n = Math.round(n / 1000) * 1000;
        range.value = Math.min(Number(range.max), n);
        input.value = n;
        coinsText.textContent = `${fmtCoins(n)} <%= currencyName %>`;
        brlText.textContent = fmtBrl(n / 1000);
      };
      range.addEventListener('input', (e) => sync(e.target.value));
      input.addEventListener('input', (e) => sync(e.target.value));
      sync(input.value);
    })();
  </script>
  <script>
    (() => {
      const codeInput = document.getElementById('streamerSupportCodeWallet');
      const syncSupportCode = () => {
        document.querySelectorAll('[data-support-code-hidden]').forEach((hidden) => { hidden.value = (codeInput?.value || '').toUpperCase().trim(); });
      };
      codeInput?.addEventListener('input', syncSupportCode);
      document.querySelectorAll('[data-coin-checkout]').forEach((form) => form.addEventListener('submit', syncSupportCode));
      syncSupportCode();
    })();
  </script>

  <section class="split account-history account-history-v33">
    <div class="card wide-card">
      <h2>Últimas movimentações</h2>
      <table>
        <thead><tr><th>Data</th><th>Motivo</th><th>Moedas</th><th>Saldo</th></tr></thead>
        <tbody>
          <% ledgers.forEach(l => { %>
            <tr><td><%= dateTime(l.createdAt) %></td><td><%= l.reason %></td><td><%= coins(l.amount) %></td><td><%= coins(l.balanceAfter) %></td></tr>
          <% }) %>
          <% if (!ledgers.length) { %><tr><td colspan="4" class="muted">Nenhuma movimentação ainda.</td></tr><% } %>
        </tbody>
      </table>
    </div>
    <div class="card wide-card">
      <h2>Entregas</h2>
      <table>
        <thead><tr><th>Item</th><th>Status</th><th>Data</th></tr></thead>
        <tbody>
          <% deliveries.forEach(d => { %>
            <tr><td><%= d.productName %></td><td><span class="status <%= d.status.toLowerCase() %>"><%= d.status %></span></td><td><%= dateTime(d.createdAt) %></td></tr>
          <% }) %>
          <% if (!deliveries.length) { %><tr><td colspan="3" class="muted">Nenhuma entrega criada ainda.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
