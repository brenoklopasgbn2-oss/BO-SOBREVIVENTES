    .v9-product-grid{display:grid!important;grid-template-columns:repeat(5,minmax(190px,1fr))!important;gap:20px;perspective:1200px}.v9-product-card{position:relative;min-height:250px;overflow:hidden;border:1px solid rgba(255,255,255,.12);border-radius:0 16px 0 16px;background:linear-gradient(180deg,rgba(14,24,38,.82),rgba(5,9,16,.92));box-shadow:0 26px 72px rgba(0,0,0,.48);transform-style:preserve-3d;transition:transform .25s,box-shadow .25s,border-color .25s}.v9-product-card:hover,.v9-product-card.is-hovered{transform:translateY(-18px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg)) scale(1.035);border-color:rgba(255,255,255,.32);box-shadow:0 45px 125px rgba(0,0,0,.80),0 0 35px rgba(239,52,52,.32);z-index:20}.v9-product-card.is-featured{border-color:rgba(239,52,52,.85);box-shadow:0 30px 92px rgba(0,0,0,.6),0 0 32px rgba(239,52,52,.28);transform:translateY(-12px) rotateZ(-2deg)}.theme-bbp .v9-product-card.is-featured{border-color:rgba(39,167,255,.85);box-shadow:0 30px 92px rgba(0,0,0,.6),0 0 32px rgba(39,167,255,.28)}.v9-product-art{height:150px;position:relative;display:grid;place-items:center;background:radial-gradient(circle at 50% 48%,rgba(39,167,255,.11),transparent 42%),linear-gradient(180deg,rgba(255,255,255,.035),rgba(0,0,0,.14))}.v9-product-art img{position:relative;z-index:3;width:82%;height:132px;object-fit:contain;filter:drop-shadow(0 22px 30px rgba(0,0,0,.75));transition:.25s}.v9-product-card:hover .v9-product-art img{transform:translateY(-12px) scale(1.13);filter:drop-shadow(0 34px 38px rgba(0,0,0,.92)) drop-shadow(0 0 26px rgba(239,52,52,.32))}.v9-product-content{padding:0 18px 18px;display:flex;flex-direction:column;min-height:110px}.v9-product-tags{display:flex;gap:8px;margin-bottom:8px;min-height:22px}.v9-product-tags span,.v9-product-tags b{height:22px;border-radius:999px;padding:4px 9px;background:rgba(2,7,14,.72);border:1px solid rgba(255,255,255,.10);font-size:.62rem;text-transform:uppercase;letter-spacing:.07em;color:#b8c3d1}.v9-product-tags b{color:#ffd36a;border-color:rgba(247,189,68,.35)}.v9-product-card h3{font-size:1.05rem;margin:0 0 3px;color:#fff;font-weight:1000}.v9-product-card p{margin:0 0 7px;color:#b7c0cd;font-size:.82rem;line-height:1.25;min-height:32px}.v9-product-mini-list{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:9px;min-height:19px}.v9-product-mini-list small{font-size:.67rem;color:#aab4c4;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.07);border-radius:7px;padding:3px 6px}.v9-product-bottom{display:flex;align-items:center;justify-content:space-between;gap:8px;margin-top:auto}.v9-product-bottom strong{display:flex;align-items:center;gap:7px;color:#ffbd35;font-size:1.22rem;font-weight:1000}.v9-product-bottom strong i{width:20px;height:20px;border-radius:50%;display:grid;place-items:center;background:radial-gradient(circle at 35% 25%,#ffe7a1,#d78b22 45%,#6c3912 80%);color:#683507;font-size:.55rem;font-style:normal}.v9-buy-btn{height:34px!important;padding:0 13px!important;border-radius:9px!important;background:rgba(10,16,26,.82)!important;border:1px solid rgba(255,255,255,.14)!important;color:#fff!important;font-size:.72rem;text-transform:uppercase;letter-spacing:.07em;opacity:.38}.v9-product-card:hover .v9-buy-btn{opacity:1;border-color:#ef3434!important}.v9-trust-strip{margin:18px 0 0;display:grid!important;grid-template-columns:repeat(4,1fr);border:1px solid rgba(255,255,255,.08);border-radius:14px;background:linear-gradient(180deg,rgba(9,17,29,.76),rgba(4,8,15,.84));box-shadow:0 22px 70px rgba(0,0,0,.44);overflow:hidden}.v9-trust-strip div{display:grid;grid-template-columns:46px 1fr;column-gap:12px;align-items:center;padding:18px 26px;border-right:1px solid rgba(255,255,255,.07)}.v9-trust-strip div:last-child{border-right:0}.v9-trust-strip b{grid-row:1/3;width:38px;height:38px;display:grid;place-items:center;color:#ff3838;font-size:1.45rem}.v9-trust-strip strong{text-transform:uppercase;letter-spacing:.12em;font-size:.78rem}.v9-trust-strip span{font-size: