    main.container.v9-store-page{max-width:1820px!important;margin:0 auto!important;padding:0 64px 34px!important;position:relative;isolation:isolate}.v9-bg{position:fixed!important;inset:74px 0 0 0!important;z-index:-2!important;background:url('/images/store-hero-main.png?v=11') left top/auto 61vh no-repeat!important;opacity:.72!important;filter:saturate(1.12) contrast(1.05)!important}.v9-bg::before{content:"";position:absolute;inset:0;background:linear-gradient(90deg,rgba(2,5,11,.12) 0%,rgba(2,5,11,.78) 43%,rgba(2,5,11,.9) 100%),linear-gradient(180deg,rgba(2,5,11,.12),#02050b 72%)}.v9-bg::after{content:"";position:absolute;inset:0;background:radial-gradient(circle at 30% 40%,rgba(239,52,52,.20),transparent 22%),radial-gradient(circle at 72% 36%,rgba(39,167,255,.22),transparent 27%)}
    .v9-hero-zone{display:grid!important;grid-template-columns:minmax(620px,1fr) minmax(490px,660px)!important;grid-template-areas:"copy wallet" "servers servers"!important;gap:24px 34px;align-items:start;min-height:455px;padding-top:52px!important}.v9-hero-copy{grid-area:copy;margin-left:310px!important;max-width:800px;text-shadow:0 10px 40px #000}.v9-kicker{margin:0 0 13px;color:#ff4545;text-transform:uppercase;letter-spacing:.22em;font-size:.78rem;font-weight:1000}.theme-bbp .v9-kicker{color:#41c4ff}.v9-hero-copy h1{margin:0 0 18px;font-family:Impact,'Arial Black',Arial,sans-serif;font-size:clamp(3rem,5vw,5.6rem);line-height:.88;text-transform:uppercase;letter-spacing:.02em;color:#f3f4f6;text-shadow:0 4px 0 rgba(255,255,255,.04),0 18px 42px #000}.v9-hero-copy h1 span{color:#e73333}.theme-bbp .v9-hero-copy h1 span{color:#2fb8ff}.v9-hero-copy p:not(.v9-kicker){margin:0;color:#c6cedb;font-size:1.02rem;line-height:1.55;font-weight:600;max-width:660px}
    .v9-wallet-hud{grid-area:wallet;min-height:150px;padding:25px 28px;display:grid!important;grid-template-columns:minmax(180px,1fr) 76px 240px;gap:18px;align-items:center;background:linear-gradient(180deg,rgba(21,17,10,.78),rgba(5,7,12,.84));border:1px solid rgba(247,189,68,.45);clip-path:polygon(0 0,93% 0,100% 30%,100% 100%,13% 100%,8% 88%,0 88%);box-shadow:0 0 0 1px rgba(247,189,68,.13),0 22px 75px rgba(0,0,0,.58),inset 0 0 60px rgba(247,189,68,.055)}.v9-wallet-text span{display:block;text-transform:uppercase;letter-spacing:.13em;color:#dad2c2;font-weight:1000;font-size:.78rem;margin-bottom:8px}.v9-wallet-text strong{display:block;font-family:Impact,'Arial Black',Arial,sans-serif;font-size:3.45rem;line-height:.92;color:#fff;letter-spacing:.04em}.v9-wallet-text small{display:block;margin-top:10px;text-transform:uppercase;letter-spacing:.12em;color:#c7bdab;font-weight:900}.v9-coin-medal{width:70px;height:70px;border-radius:50%;display:grid;place-items:center;background:radial-gradient(circle at 35% 28%,#ffeaa8,#d98d22 42%,#6c3912 76%);border:4px double rgba(75,39,7,.8);color:#673508;font-weight:1000;box-shadow:0 0 30px rgba(247,189,68,.45)}.v9-gold-btn{height:58px;border-radius:3px!important;border:1px solid rgba(247,189,68,.55)!important;background:linear-gradient(135deg,rgba(108,62,10,.74),rgba(13,12,10,.82))!important;color:#ffe08a!important;text-transform:uppercase;letter-spacing:.08em;font-size:.84rem;white-space:nowrap}.v9-gold-btn span{font-size:1.45rem;color:#ffcc45}
