    .v10-login-panel{display:grid;grid-template-columns:1fr 1.55fr;gap:22px;align-items:center;margin:22px 0 16px 255px;padding:20px 24px;border:1px solid rgba(247,189,68,.22);border-radius:16px;background:linear-gradient(135deg,rgba(12,18,30,.78),rgba(5,8,14,.88));box-shadow:0 24px 72px rgba(0,0,0,.44)}.v10-login-panel h2{margin:0 0 8px;text-transform:uppercase}.v10-login-panel p{margin:0;color:#adb8c8}.v10-login-form{display:grid;grid-template-columns:1.4fr 1fr auto;gap:10px}input{background:rgba(2,6,12,.82);border:1px solid rgba(255,255,255,.14);border-radius:12px;color:#fff;padding:13px;font:inherit;outline:none}input:focus{border-color:#ef3434;box-shadow:0 0 0 3px rgba(239,52,52,.15)}
