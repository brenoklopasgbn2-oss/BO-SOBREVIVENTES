    .v9-brand{display:flex!important;align-items:center;gap:13px;min-width:0;text-transform:uppercase;letter-spacing:.02em}.v9-logo-wrap{width:58px!important;height:58px!important;min-width:58px;display:grid;place-items:center;border-radius:17px;filter:drop-shadow(0 10px 30px rgba(0,0,0,.70))}.v9-logo-wrap img{width:58px!important;height:58px!important;max-width:58px!important;max-height:58px!important;object-fit:cover!important;border-radius:16px!important;border:1px solid rgba(255,255,255,.18);box-shadow:0 0 28px rgba(239,52,52,.18)}.v9-brand strong{display:block;font-size:1.12rem;line-height:1.02;font-weight:1000;color:#fff}.v9-brand strong b{color:#ef3434}.v9-brand small{display:block;margin-top:3px;font-size:.66rem;color:#a8b1c1;font-weight:900;letter-spacing:.11em}.v9-main-nav{display:flex!important;justify-content:center;align-items:center;gap:24px}.v9-nav-item{height:74px;display:flex!important;align-items:center;gap:9px;padding:0!important;border:0!important;background:transparent!important;color:#ccd3df!important;text-transform:uppercase;font-size:.76rem;font-weight:1000;letter-spacing:.15em;position:relative;white-space:nowrap}.v9-nav-item span{font-size:1.08rem}.v9-nav-item::after{content:"";position:absolute;left:0;right:0;bottom:0;height:3px;background:#ef3434;box-shadow:0 0 18px #ef3434;transform:scaleX(0);transition:.2s}.v9-nav-item:hover::after,.v9-nav-item.active::after{transform:scaleX(1)}.v9-account-nav{display:flex!important;justify-content:flex-end;align-items:center;gap:12px}.v9-account-pill{height:58px;display:flex!important;align-items:center;gap:12px;padding:0 18px!important;color:#fff!important;background:rgba(8,12,20,.46)!important;border:1px solid rgba(255,255,255,.06)!important;min-width:210px}.v9-account-icon{width:36px;height:36px;border-radius:50%;display:grid;place-items:center;border:1px solid rgba(255,255,255,.45)}.v9-account-pill strong{display:block;font-size:.77rem;text-transform:uppercase;letter-spacing:.08em}.v9-account-pill 