  <style id="sz-critical-v10">
    :root{--bg:#02050b;--text:#f7f9ff;--muted:#aab4c3;--line:rgba(255,255,255,.10);--red:#ef3434;--blue:#27a7ff;--gold:#f7bd44;--card:rgba(7,13,23,.72)}
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;min-height:100vh;background:#02050b;color:var(--text);font-family:Inter,Arial,Helvetica,sans-serif;overflow-x:hidden}a{text-decoration:none;color:inherit}img{max-width:100%;display:block}.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;border:1px solid rgba(255,255,255,.16);background:rgba(10,17,29,.82);color:#fff;border-radius:12px;padding:12px 16px;font-weight:900;cursor:pointer;transition:.22s}.btn:hover{transform:translateY(-2px);filter:brightness(1.1)}
    body::before{content:"";position:fixed;inset:0;z-index:-4;background:radial-gradient(circle at 13% 27%,rgba(39,167,255,.17),transparent 28%),radial-gradient(circle at 72% 32%,rgba(239,52,52,.14),transparent 30%),linear-gradient(180deg,#030914 0%,#02050b 74%);pointer-events:none}body::after{content:"";position:fixed;inset:0;z-index:-3;background:linear-gradient(90deg,rgba(2,5,11,.82),rgba(2,5,11,.45),rgba(2,5,11,.92));pointer-events:none}
