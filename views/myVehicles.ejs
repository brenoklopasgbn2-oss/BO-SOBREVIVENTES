<%- include('partials/head') %>
<%- include('partials/nav') %>
<%
  const garageVehicles = Array.isArray(vehicles) ? vehicles : [];
  const allVehicles = Array.isArray(allGarageVehicles) ? allGarageVehicles : garageVehicles;
  const nowMs = Date.now();
  const activeVehicleCount = allVehicles.filter(v => v.status === 'ACTIVE' && !(v.expiresAt && new Date(v.expiresAt).getTime() < nowMs)).length;
  const insuredVehicleCount = allVehicles.filter(v => !!v.insurancePlanId || !!v.insurancePlan).length;
  const vanillaCount = allVehicles.filter(v => v.serverType === 'vanilla').length;
  const selectedLabel = selectedGarageServer === 'vanilla' ? 'Vanilla' : 'Todos os veículos';
  const vehicleImage = (v) => { const base = v?.template?.imageData ? ('/vehicle-image/' + v.template.id) : (v?.template?.imageUrl || '/images/vanilla-card.png?v=68'); return base + (base.includes('?') ? '&' : '?') + 'v=' + (v?.template?.updatedAt ? new Date(v.template.updatedAt).getTime() : Date.now()); };
  const serverLabel = (v) => String(v?.serverType || 'vanilla').toUpperCase();
  const planLabel = (v) => v?.insurancePlan ? v.insurancePlan.name : 'Sem seguro';
  const planModeLabel = (v) => {
    if (!v?.insurancePlan) return 'Sem plano';
    if (v.insurancePlan.billingType === 'PER_USE') return 'Seguro por uso';
    return (v.insurancePlan.durationDays || 30) >= 30 ? 'Mensal' : `${v.insurancePlan.durationDays || 30} dias`;
  };
  const weeklyLimit = (v) => v?.insurancePlan?.billingType === 'SUBSCRIPTION' ? Number(v.insurancePlan.maxUsesPerWeek || 1) : null;
  const insurancePlanPrice = (plan, v) => plan?.billingType === 'PER_USE' ? 10000 : Math.round(Number(v?.template?.buyPriceCoins || 0) * 0.5);
  const weeklyText = (v) => {
    if (!v?.insurancePlan) return '0/0';
    if (v.insurancePlan.billingType === 'PER_USE') return `${v.insuranceUsesThisWeek || 0}/livre`;
    return `${v.insuranceUsesThisWeek || 0}/${weeklyLimit(v) || 1}`;
  };
  const weeklyPct = (v) => {
    const max = weeklyLimit(v);
    if (!max) return 18;
    return Math.max(4, Math.min(100, ((v.insuranceUsesThisWeek || 0) / max) * 100));
  };
  const activeFor = (v) => v.status === 'ACTIVE' && !(v.expiresAt && new Date(v.expiresAt).getTime() < nowMs);
  const hasInsurance = (v) => !!v?.insurancePlanId || !!v?.insurancePlan;
  const pendingClaimVehicleIds = new Set((logs || [])
    .filter(l => l.status === 'PENDING' && ['RESPAWN', 'ADMIN_RESPAWN'].includes(l.action))
    .map(l => l.playerVehicleId));
  const hasPendingClaim = (v) => pendingClaimVehicleIds.has(v.id);
%>
<main class="garage-shell-v29">
  <div class="garage-bg-v29" aria-hidden="true"></div>
  <%- include('partials/alerts') %>

  <div class="garage-layout-v29">
    <aside class="garage-side-v29" aria-label="Menu da garagem">
      <a class="garage-side-link active" href="/my-vehicles">
        <span>▣</span><b>Minha Garagem</b>
      </a>
      <a class="garage-side-link" href="#seguros">
        <span>盾</span><b>Seguros</b>
      </a>
      <a class="garage-side-link" href="/shop?category=<%= encodeURIComponent('Veículos') %>">
        <span>▤</span><b>Reposições</b>
      </a>
      <a class="garage-side-link" href="#historico">
        <span>◷</span><b>Histórico</b>
      </a>
      <a class="garage-side-link" href="/shop?serverType=vanilla&category=<%= encodeURIComponent('Veículos') %>">
        <span>★</span><b>Planos</b>
      </a>
      <a class="garage-side-link" href="/wallet">
        <span>◉</span><b>Suporte</b>
      </a>
    </aside>

    <section class="garage-main-v29">
      <section class="garage-hero-v29">
        <div class="garage-title-v29">
          <p class="v9-kicker">RAID-Z Store</p>
          <h1>MINHA GARAGEM</h1>
          <p>Gerencie seus veículos, veja o servidor de cada carro, acione seguro normal ou seguro por roubo e controle suas reposições.</p>
          <div class="garage-server-tabs-v29" aria-label="Filtro de servidor da garagem">
            <a class="<%= selectedGarageServer === 'all' ? 'active' : '' %>" href="/my-vehicles">Todos <b><%= allVehicles.length %></b></a>
            <a class="server-vanilla <%= selectedGarageServer === 'vanilla' ? 'active' : '' %>" href="/my-vehicles?serverType=vanilla">Vanilla <b><%= vanillaCount %></b></a>
          </div>
        </div>

        <div class="garage-stats-v29">
          <article class="garage-stat-v29 coins">
            <span>◉</span>
            <small>Saldo</small>
            <strong><%= coins(player?.coins || 0) %></strong>
            <em>RZ Coins</em>
          </article>
          <article class="garage-stat-v29 cars">
            <span>🚘</span>
            <small>Veículos ativos</small>
            <strong><%= activeVehicleCount %></strong>
            <em><%= selectedLabel %></em>
          </article>
          <article class="garage-stat-v29 shield">
            <span>盾</span>
            <small>Seguros disponíveis</small>
            <strong><%= insuredVehicleCount %></strong>
            <em>normal + roubo</em>
          </article>
        </div>
      </section>

      <section class="garage-current-server-v29">
        <span>Servidor visualizado:</span>
        <strong><%= selectedLabel %></strong>
        <small>Cada card mostra o servidor do veículo e já usa as imagens atualizadas da loja.</small>
      </section>

      <% if (garageVehicles.length) { %>
        <section class="garage-carousel-v29" aria-label="Lista de veículos da garagem">
          <button class="garage-carousel-arrow" type="button" data-garage-scroll="-1" aria-label="Voltar">‹</button>
          <div class="garage-vehicle-row-v29" data-garage-row>
            <% garageVehicles.forEach((v, index) => { %>
              <% const expired = v.expiresAt && new Date(v.expiresAt).getTime() < nowMs; %>
              <% const isActive = activeFor(v); %>
              <% const image = vehicleImage(v); %>
              <% const pendingClaim = hasPendingClaim(v); %>
              <article class="garage-vehicle-card-v29 <%= index === 0 ? 'active' : '' %> server-<%= v.serverType %> sz-hover-card" data-garage-card="<%= v.id %>">
                <div class="garage-card-art-v29">
                  <img src="<%= image %>" alt="<%= v.displayName %>">
                  <span class="garage-server-chip-v29 <%= v.serverType %>"><%= serverLabel(v) %></span>
                  <span class="garage-live-chip-v29 <%= pendingClaim ? 'moving' : 'stopped' %>"><%= pendingClaim ? 'Seguro pendente' : 'Fila local pronta' %></span>
                </div>
                <div class="garage-card-content-v29">
                  <h2><%= v.displayName %></h2>
                  <div class="garage-card-meta-v29">
                    <span>▣ Integração: arquivos locais + FTP</span>
                    <span>◉ Estado: <%= pendingClaim ? 'aguardando o mod concluir' : 'sem reposição pendente' %></span>
                    <span>★ Plano: <%= planLabel(v) %></span>
                    <span>盾 Usos na semana: <%= weeklyText(v) %></span>
                    <% if (pendingClaim) { %>
                      <span class="garage-card-location-v31">⌛ O carro antigo será removido somente quando estiver parado e vazio.</span>
                    <% } %>
                  </div>
                  <div class="garage-card-buttons-v29">
                    <button type="button" data-garage-detail="<%= v.id %>">Detalhes</button>
                    <button type="button" disabled><%= pendingClaim ? 'Processando por arquivo' : 'Sem consulta ao jogo' %></button>
                    <button type="button" class="accent" data-garage-detail="<%= v.id %>" data-scroll-actions="1"><%= pendingClaim ? 'Ver pendência' : 'Acionar seguro' %></button>
                  </div>
                </div>
              </article>
            <% }) %>
          </div>
          <button class="garage-carousel-arrow" type="button" data-garage-scroll="1" aria-label="Avançar">›</button>
        </section>

        <% garageVehicles.forEach((v, index) => { %>
          <% const expired = v.expiresAt && new Date(v.expiresAt).getTime() < nowMs; %>
          <% const isActive = activeFor(v); %>
          <% const image = vehicleImage(v); %>
          <% const pendingClaim = hasPendingClaim(v); %>
          <% const planOptions = (availablePlans || []).filter(p => !p.templateId || p.templateId === v.templateId); %>
          <section class="garage-detail-v29 <%= index === 0 ? 'active' : '' %> server-<%= v.serverType %>" id="garage-detail-<%= v.id %>" data-garage-panel="<%= v.id %>">
            <div class="garage-detail-info-v29">
              <div class="garage-detail-title-v29">
                <h2><%= v.displayName %></h2>
                <div class="garage-detail-tags-v29">
                  <span class="ok"><%= isActive ? 'ACTIVE' : (expired ? 'VENCIDO' : v.status) %></span>
                  <span class="server"><%= serverLabel(v) %></span>
                  <span>Processamento local</span>
                  <span><%= pendingClaim ? 'Reposição pendente' : 'Sem pendência' %></span>
                </div>
              </div>

              <div class="garage-detail-grid-v29">
                <div><small>Servidor do veículo</small><strong><%= serverLabel(v) %></strong></div>
                <div><small>Seguro atual</small><strong><%= planModeLabel(v) %></strong></div>
                <div><small>Seguro por roubo</small><strong class="<%= pendingClaim ? 'orange' : 'green' %>"><%= pendingClaim ? 'Aguardando conclusão local' : 'Disponível para acionar' %></strong></div>
                <div><small>Comunicação</small><strong>Arquivos locais + FTP</strong></div>
                <div><small>Consulta ao jogo</small><strong>Desativada</strong></div>
                <div><small>Regra de remoção</small><strong>Somente parado e sem ocupantes</strong></div>
                <div><small>Veículo vence</small><strong><%= v.expiresAt ? dateTime(v.expiresAt) : 'Permanente' %></strong></div>
              </div>
            </div>

            <div class="garage-detail-art-v29">
              <img src="<%= image %>" alt="<%= v.displayName %>">
              <div class="garage-usage-v29">
                <small>Usos na semana</small>
                <strong><%= weeklyText(v) %></strong>
                <span><i style="width:<%= weeklyPct(v) %>%"></i></span>
                <em>Total de seguros usados: <%= v.insuranceUsesTotal || 0 %></em>
                <b>Plano atual: <%= planLabel(v) %></b>
              </div>
            </div>

            <aside class="garage-actions-v29" id="garage-actions-<%= v.id %>">
              <% if (v.insurancePlan) { %>
                <form method="POST" action="/my-vehicles/<%= v.id %>/respawn">
                  <input type="hidden" name="coverageType" value="NORMAL">
                  <button class="garage-action-option-v29 normal" type="submit" <%= (!isActive || pendingClaim) ? 'disabled' : '' %>>
                    <span>盾</span>
                    <b>Acionar seguro normal</b>
                    <small>Requer estar até 250m do veículo</small>
                  </button>
                </form>
                <form method="POST" action="/my-vehicles/<%= v.id %>/respawn">
                  <input type="hidden" name="coverageType" value="THEFT">
                  <button class="garage-action-option-v29 theft" type="submit" <%= (!isActive || pendingClaim) ? 'disabled' : '' %>>
                    <span>♟</span>
                    <b>Acionar seguro por roubo</b>
                    <small><%= pendingClaim ? 'Já existe uma reposição pendente' : 'Sem limite de distância; aguarda parar e esvaziar' %></small>
                  </button>
                </form>
              <% } else { %>
                <div class="garage-action-option-v29 blocked">
                  <span>×</span>
                  <b>Sem seguro ativo</b>
                  <small>Adicione um plano para liberar reposição</small>
                </div>
              <% } %>

              <% if (planOptions.length) { %>
                <form method="POST" action="/my-vehicles/<%= v.id %>/upgrade-insurance" class="garage-upgrade-v29">
                  <label>Plano de seguro
                    <select name="planId" required>
                      <% planOptions.forEach(plan => { %>
                        <option value="<%= plan.id %>" <%= v.insurancePlanId === plan.id ? 'selected' : '' %>>
                          <%= plan.name %> — <%= plan.billingType === 'PER_USE' ? ('por uso ' + coins(insurancePlanPrice(plan, v)) + ' RZ') : ('mensal ' + coins(insurancePlanPrice(plan, v)) + ' RZ / ' + plan.maxUsesPerWeek + 'x semana') %>
                        </option>
                      <% }) %>
                    </select>
                  </label>
                  <button class="garage-action-option-v29 upgrade" type="submit">
                    <span>⇧</span>
                    <b><%= v.insurancePlanId ? 'Upgrade de plano' : 'Adicionar seguro' %></b>
                    <small>Seguro por uso 10k ou mensal 50% do veículo. Na compra do carro, o 1º mês já vem incluso.</small>
                  </button>
                </form>
              <% } %>

              <% if (v.ownershipType !== 'OWNED') { %>
                <form method="POST" action="/my-vehicles/<%= v.id %>/renew">
                  <input type="hidden" name="days" value="30">
                  <button class="garage-action-option-v29 renew" type="submit">
                    <span>↻</span>
                    <b>Renovar veículo</b>
                    <small>Adicionar mais 30 dias</small>
                  </button>
                </form>
              <% } %>

              <% if (v.insurancePlan?.billingType === 'SUBSCRIPTION') { %>
                <form method="POST" action="/my-vehicles/<%= v.id %>/renew-insurance">
                  <button class="garage-action-option-v29 renew" type="submit">
                    <span>⟳</span>
                    <b>Renovar seguro</b>
                    <small>Reinicia validade do plano mensal</small>
                  </button>
                </form>
              <% } %>

              <form method="POST" action="/my-vehicles/<%= v.id %>/cancel">
                <button class="garage-action-option-v29 cancel" type="submit">
                  <span>×</span>
                  <b>Cancelar veículo</b>
                  <small>Remover veículo da sua garagem</small>
                </button>
              </form>
            </aside>
          </section>
        <% }) %>
      <% } else { %>
        <section class="garage-empty-v29">
          <h2>Nenhum veículo nessa garagem</h2>
          <p>Doe um veículo na categoria Veículos. Todo veículo com seguro aparece aqui para reposição.</p>
          <a class="btn v9-gold-btn" href="/shop?serverType=vanilla&category=<%= encodeURIComponent('Veículos') %>">Ver veículos</a>
        </section>
      <% } %>

      <section class="garage-insurance-explain-v29" id="seguros">
        <h2>COMO FUNCIONAM OS SEGUROS</h2>
        <div class="garage-insurance-cards-v29">
          <article class="normal">
            <span>盾</span>
            <div>
              <h3>Seguro normal</h3>
              <p>Use quando você está perto do veículo. O player precisa estar até <b>250m</b> do carro antigo. O sistema remove somente o veículo com o ID salvo e cria uma nova reposição.</p>
            </div>
          </article>
          <article class="theft">
            <span>♟</span>
            <div>
              <h3>Seguro por roubo</h3>
              <p>Use quando seu carro foi levado por outros jogadores. O player pode estar em qualquer canto do mapa. O sistema ignora a distância e só apaga quando o carro estiver <b>parado</b> e <b>sem player dentro</b>.</p>
            </div>
          </article>
        </div>
      </section>

      <section class="garage-history-v29" id="historico">
        <div class="garage-section-title-v29">
          <p class="v9-kicker">Histórico</p>
          <h2>Últimas ações da garagem</h2>
        </div>
        <div class="garage-history-table-v29">
          <table>
            <thead><tr><th>Data</th><th>Ação</th><th>Custo</th><th>Status</th><th>Novo ID</th></tr></thead>
            <tbody>
              <% logs.forEach(l => { %>
                <tr><td><%= dateTime(l.createdAt) %></td><td><%= l.action %></td><td><%= coins(l.costCoins) %> RZ</td><td><span class="status <%= l.status.toLowerCase() %>"><%= l.status %></span></td><td><code><%= l.newVehicleKey || '-' %></code></td></tr>
              <% }) %>
              <% if (!logs.length) { %><tr><td colspan="5" class="muted">Sem histórico ainda.</td></tr><% } %>
            </tbody>
          </table>
        </div>
      </section>
    </section>
  </div>
</main>
<script id="garage-v29-script">
  (() => {
    const row = document.querySelector('[data-garage-row]');
    document.querySelectorAll('[data-garage-scroll]').forEach((btn) => {
      btn.addEventListener('click', () => row?.scrollBy({ left: Number(btn.dataset.garageScroll || 1) * 460, behavior: 'smooth' }));
    });

    function showGaragePanel(id, scrollActions = false) {
      document.querySelectorAll('[data-garage-card]').forEach(card => card.classList.toggle('active', card.dataset.garageCard === id));
      document.querySelectorAll('[data-garage-panel]').forEach(panel => panel.classList.toggle('active', panel.dataset.garagePanel === id));
      const target = document.getElementById(scrollActions ? `garage-actions-${id}` : `garage-detail-${id}`);
      target?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    document.querySelectorAll('[data-garage-detail]').forEach((btn) => {
      btn.addEventListener('click', () => showGaragePanel(btn.dataset.garageDetail, btn.dataset.scrollActions === '1'));
    });
  })();
</script>
<%- include('partials/footer') %>
