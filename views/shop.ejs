      <article class="rz-product-card-v118 product-card-pro v9-product-card sz-hover-card <%= product.featured ? 'is-featured' : '' %> <%= product.promo?.active ? 'is-promo' : '' %>" style="--featured-color:<%= featuredColor %>;--featured-rgb:<%= hexToRgb(featuredColor) %>;--promo-color:<%= promoColorFor(product) %>;--promo-rgb:<%= hexToRgb(promoColorFor(product)) %>;" data-store-card data-store-price="<%= product.displayPriceCoins %>" data-store-title="<%= product.name.toLowerCase() %>" data-product-name="<%= `${product.name} ${product.category} ${product.description || ''}`.toLowerCase() %>" data-cart-product-id="<%= product.id %>" data-cart-name="<%= product.name %>" data-cart-category="<%= product.category %>" data-cart-server="<%= product.serverType %>" data-cart-price="<%= product.displayPriceCoins %>" data-cart-image="<%= visualSrc %>">
