<script id="vehicle-config-modal-v32-script">
  document.querySelectorAll('[data-open-vehicle-config]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modal = document.getElementById(btn.dataset.openVehicleConfig);
      if (!modal) return;
      modal.hidden = false;
      document.body.classList.add('vehicle-modal-open-v32');
      const box = modal.querySelector('.vehicle-config-box-v32');
      const content = modal.querySelector('.vehicle-config-content-v32');
      const preview = modal.querySelector('.vehicle-config-preview-v32');
      if (box) box.scrollTop = 0;
      if (content) content.scrollTop = 0;
      if (preview) preview.scrollTop = 0;
      requestAnimationFrame(() => {
        if (box) box.scrollTop = 0;
        box?.scrollIntoView({ block: 'center', inline: 'center' });
      });
    });
  });
  document.querySelectorAll('[data-close-vehicle-config]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modal = btn.closest('.vehicle-config-modal-v32');
      if (!modal) return;
      modal.hidden = true;
      document.body.classList.remove('vehicle-modal-open-v32');
    });
  });
  document.addEventListener('keydown', (ev) => {
    if (ev.key !== 'Escape') return;
    document.querySelectorAll('.vehicle-config-modal-v32:not([hidden])').forEach((modal) => { modal.hidden = true; });
    document.body.classList.remove('vehicle-modal-open-v32');
  });
  document.querySelectorAll('.vehicle-config-modal-v32').forEach((modal) => {
    modal.querySelectorAll('[data-variant-choice]').forEach((choice) => {
      choice.addEventListener('click', () => {
        modal.querySelectorAll('[data-variant-choice]').forEach((item) => item.classList.remove('active'));
        choice.classList.add('active');
        const input = modal.querySelector('[data-variant-input]');
        const preview = modal.querySelector('[data-variant-preview-img]');
        const name = modal.querySelector('[data-variant-name]');
        const className = modal.querySelector('[data-variant-class]');
        if (input) input.value = choice.dataset.index || '0';
        if (preview && choice.dataset.img) preview.src = choice.dataset.img;
        if (name) name.textContent = choice.dataset.name || 'Padrão';
        if (className) className.textContent = choice.dataset.class || '';
      });
    });
  });
</script>
<script id="store-filter-scroll-script">
  document.querySelectorAll('[data-cat-scroll]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const area = btn.parentElement?.querySelector('[data-cat-scroll-area]');
      if (!area) return;
      area.scrollBy({ left: Number(btn.dataset.catScroll || 1) * 280, behavior: 'smooth' });
    });
  });
  const filterArea = document.querySelector('[data-cat-scroll-area]');
  if (filterArea) {
    filterArea.addEventListener('wheel', (ev) => {
      if (Math.abs(ev.deltaY) > Math.abs(ev.deltaX)) {
        filterArea.scrollLeft += ev.deltaY;
        ev.preventDefault();
      }
    }, { passive: false });
  }
</script>

<script id="shop-category-autoscroll-v83">
  (function(){
    const grid = document.getElementById('productsGrid');
    if (!grid) return;
    const topbar = document.querySelector('.topbar.v9-topbar');
    const offset = ((topbar && topbar.offsetHeight) || 64) + 12;
    const goToGrid = () => {
      const y = grid.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
    };
    const url = new URL(window.location.href);
    if (url.hash === '#productsGrid' || url.searchParams.has('category')) {
      requestAnimationFrame(() => setTimeout(goToGrid, 60));
    }
    document.querySelectorAll('.category-button-v32[href*="#productsGrid"]').forEach((link) => {
      link.addEventListener('click', () => {
        sessionStorage.setItem('rzScrollToProducts', '1');
      });
    });
    if (sessionStorage.getItem('rzScrollToProducts') === '1') {
      sessionStorage.removeItem('rzScrollToProducts');
      requestAnimationFrame(() => setTimeout(goToGrid, 60));
    }
  })();
</script>
