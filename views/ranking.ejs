<%- include('partials/head') %>
<link rel="stylesheet" href="/css/ranking-v117.css?v=119">
<%- include('partials/nav') %>

<main class="rz-ranking-page">
  <div class="rz-ranking-backdrop" aria-hidden="true"></div>
  <%- include('partials/alerts') %>

  <section class="rz-rank-hero">
    <div class="rz-rank-emblem" aria-hidden="true">
      <img src="/images/ranking/trophies/champion-cup.svg" alt="">
    </div>
    <div class="rz-rank-hero-copy">
      <span class="rz-eyebrow">Ranking</span>
      <h1>Dominar é evoluir</h1>
      <p>Acompanhe os melhores players e clãs do servidor, confira confrontos e desbloqueie troféus automaticamente.</p>
    </div>
    <div class="rz-rank-hero-mark" aria-hidden="true">RZ</div>
  </section>

  <nav class="rz-rank-tabs" aria-label="Seções do ranking">
    <a class="active" href="#players"><span>♙</span> Players</a>
    <a href="#clas"><span>⬡</span> Clãs</a>
    <a href="#confrontos"><span>⌖</span> Quem matou quem</a>
    <a href="#trofeus"><span>♛</span> Troféus</a>
    <a href="/clans#criar-cla"><span>⊞</span> Criar clã</a>
    <% if (player) { %><a href="/ranking/me?server=<%= selectedServer %>"><span>◎</span> Meu perfil</a><% } %>
  </nav>

  <section class="rz-filter-strip" aria-label="Filtros do ranking">
    <div class="rz-filter-group">
      <span>Servidor</span>
      <% [['global','Global'],['vanilla','Vanilla'],['bbp','BBP'],['deathmatch','Deathmatch']].forEach(([value,label]) => { %>
        <a class="<%= selectedServer === value ? 'active' : '' %>" href="/ranking?server=<%= value %>&period=<%= selectedPeriod %>"><%= label %></a>
      <% }) %>
    </div>
    <div class="rz-filter-group rz-filter-periods">
      <span>Período</span>
      <% [['daily','Hoje'],['weekly','7 dias'],['monthly','30 dias'],['season','Temporada'],['all','Histórico']].forEach(([value,label]) => { %>
        <a class="<%= selectedPeriod === value ? 'active' : '' %>" href="/ranking?server=<%= selectedServer %>&period=<%= value %>"><%= label %></a>
      <% }) %>
    </div>
    <div class="rz-filter-summary">
      <span>Período atual</span>
      <strong><%= range.label %></strong>
    </div>
  </section>

  <section class="rz-rank-panel" id="players">
    <header class="rz-panel-head">
      <div>
        <h2>Top players</h2>
        <p>Score = kills, headshots, distância, troféus e menos mortes.</p>
      </div>
      <div class="rz-panel-period"><span>◷</span> <%= range.label %></div>
    </header>

    <div class="rz-rank-table-wrap">
      <table class="rz-rank-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Player</th>
            <th>Steam64</th>
            <th>Kills</th>
            <th>Mortes</th>
            <th>KD</th>
            <th>HS</th>
            <th>Troféus</th>
            <th>Arma favorita</th>
            <th>Quem mais matou</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody>
          <% playerRanking.slice(0, 50).forEach((p, index) => { %>
            <tr class="<%= index < 3 ? 'rz-podium-row rz-podium-' + (index + 1) : '' %>">
              <td><span class="rz-rank-position"><%= index + 1 %></span></td>
              <td>
                <a class="rz-player-cell" href="/ranking/player/<%= p.steam64 %>?server=<%= selectedServer %>">
                  <img src="<%= p.avatarUrl %>" alt="Avatar de <%= p.name %>" onerror="this.onerror=null;this.src='/images/raidz-profile-default.webp'">
                  <span>
                    <strong><%= p.clan ? ('[' + p.clan.tag + '] ') : '' %><%= p.name %></strong>
                    <small><%= p.clan ? p.clan.name : (p.profileBio || 'Sobrevivente RAID-Z') %></small>
                  </span>
                </a>
              </td>
              <td><code><%= p.steam64 %></code></td>
              <td><strong><%= p.kills %></strong></td>
              <td><%= p.deaths %></td>
              <td><strong class="<%= p.kd >= 1 ? 'rz-positive' : 'rz-negative' %>"><%= Number(p.kd).toFixed(2) %></strong></td>
              <td><%= p.headshots %></td>
              <td>
                <div class="rz-mini-trophies" title="<%= (p.badges || []).length %> troféu(s)">
                  <% (p.badges || []).slice(0, 3).forEach((badge) => { %>
                    <span style="--trophy:<%= badge.color || '#f7bd44' %>">
                      <% if (badge.imageUrl) { %><img src="<%= badge.imageUrl %>" alt=""><% } else { %><%= badge.icon || '🏆' %><% } %>
                    </span>
                  <% }) %>
                  <b><%= (p.badges || []).length %></b>
                </div>
              </td>
              <td><span class="rz-weapon-name"><%= p.favoriteWeapon %></span></td>
              <td>
                <% const topVictimSteam64 = p.topVictim ? p.victimSteam64s[p.topVictim[0]] : null; %>
                <% if (p.topVictim && topVictimSteam64) { %>
                  <a class="rz-rival-link" href="/ranking/player/<%= topVictimSteam64 %>?server=<%= selectedServer %>"><%= p.topVictim[0] %> <em>x<%= p.topVictim[1] %></em></a>
                <% } else if (p.topVictim) { %>
                  <span class="rz-rival-link"><%= p.topVictim[0] %> <em>x<%= p.topVictim[1] %></em></span>
                <% } else { %>—<% } %>
              </td>
              <td><strong class="rz-score <%= p.score < 0 ? 'negative' : '' %>"><%= coins(p.score) %></strong></td>
            </tr>
          <% }) %>
          <% if (!playerRanking.length) { %>
            <tr><td colspan="11" class="rz-empty">Ainda não há kills registradas neste período. O ranking será preenchido automaticamente pelo FTP.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="rz-clan-section" id="clas">
    <header class="rz-section-title"><span>♙</span><h2>Ranking de clãs</h2></header>
    <div class="rz-clan-grid">
      <% clanRanking.slice(0, 6).forEach((clan, index) => { %>
        <a class="rz-clan-card <%= index === 0 ? 'champion' : '' %>" href="/clans/<%= clan.slug %>" style="--clan-accent:<%= clan.accentColor %>">
          <div class="rz-clan-bg" style="background-image:url('<%= clan.bannerUrl %>')"></div>
          <span class="rz-clan-position"><%= index + 1 %></span>
          <div class="rz-clan-flag"><img src="<%= clan.flagUrl %>" alt="Bandeira do clã <%= clan.name %>" onerror="this.onerror=null;this.src='/images/raidz-clan-default.webp'"></div>
          <div class="rz-clan-copy">
            <small>TAG</small>
            <h3>[<%= clan.tag %>] <%= clan.name %></h3>
            <p><%= clan.description || 'Clã competitivo cadastrado no RAID-Z.' %></p>
            <div class="rz-clan-stats">
              <span><small>Kills</small><strong><%= clan.kills %></strong></span>
              <span><small>Mortes</small><strong><%= clan.deaths %></strong></span>
              <span><small>KD</small><strong><%= Number(clan.kd).toFixed(2) %></strong></span>
              <span><small>Membros</small><strong><%= clan.membersCount %></strong></span>
            </div>
          </div>
          <div class="rz-clan-trophy">
            <img src="<%= index === 0 ? '/images/ranking/trophies/champion-cup.svg' : '/images/ranking/trophies/silver-cup.svg' %>" alt="">
            <strong><%= (clan.awards || []).length %></strong>
            <small><%= (clan.awards || []).length ? 'troféu(s)' : 'sem troféu ainda' %></small>
          </div>
        </a>
      <% }) %>
      <% if (!clanRanking.length) { %><div class="rz-empty-card">Nenhum clã cadastrado no ranking.</div><% } %>
    </div>
    <% if (clanRanking.length > 6) { %><a class="rz-wide-action" href="/clans">Ver ranking completo de clãs <span>⌄</span></a><% } %>
  </section>

  <section class="rz-bottom-grid">
    <article class="rz-rank-panel rz-feed-panel" id="confrontos">
      <header class="rz-panel-head compact">
        <div><h2>Quem matou quem</h2><p>Últimos eventos recebidos do servidor.</p></div>
      </header>
      <div class="rz-kill-feed">
        <% recentKills.slice(0, 12).forEach((kill) => { %>
          <div class="rz-kill-row">
            <span class="rz-crosshair">⌖</span>
            <a href="/ranking/player/<%= kill.killerSteam64 %>?server=<%= selectedServer %>"><%= kill.killerName || kill.killerSteam64 %></a>
            <span class="rz-gun">➜</span>
            <a href="/ranking/player/<%= kill.victimSteam64 %>?server=<%= selectedServer %>"><%= kill.victimName || kill.victimSteam64 %></a>
            <b>x1</b>
            <time><%= dateTime(kill.occurredAt) %></time>
            <small><%= kill.weapon || 'Arma desconhecida' %><%= kill.distanceMeters ? ' • ' + Math.round(kill.distanceMeters) + 'm' : '' %><%= kill.headshot ? ' • HEADSHOT' : '' %></small>
          </div>
        <% }) %>
        <% if (!recentKills.length) { %><div class="rz-empty">Sem eventos neste período.</div><% } %>
      </div>
    </article>

    <article class="rz-rank-panel rz-trophy-panel" id="trofeus">
      <header class="rz-panel-head compact">
        <div><h2>Troféus e títulos dos players</h2><p>As conquistas são liberadas automaticamente conforme o histórico.</p></div>
        <a href="#catalogo-trofeus">Ver todos</a>
      </header>
      <div class="rz-trophy-showcase">
        <% latestTrophies.slice(0, 6).forEach((badge) => { %>
          <a class="rz-trophy-card" href="/ranking/player/<%= badge.steam64 %>?server=<%= selectedServer %>" style="--trophy:<%= badge.color || '#f7bd44' %>">
            <div class="rz-trophy-icon"><% if (badge.imageUrl) { %><img src="<%= badge.imageUrl %>" alt=""><% } else { %><span><%= badge.icon || '🏆' %></span><% } %></div>
            <div><strong><%= badge.title %></strong><p><%= badge.description || 'Conquista do RAID-Z.' %></p><small>Conquistado por <%= badge.playerName || badge.steam64 %></small></div>
          </a>
        <% }) %>
        <% if (!latestTrophies.length) { %>
          <% trophyCatalog.slice(0, 3).forEach((trophy) => { %>
            <div class="rz-trophy-card locked" style="--trophy:<%= trophy.color %>">
              <div class="rz-trophy-icon"><img src="<%= trophy.imageUrl %>" alt=""></div>
              <div><strong><%= trophy.title %></strong><p><%= trophy.description %></p><small>Ninguém conquistou ainda</small></div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </article>
  </section>

  <section class="rz-rank-panel rz-catalog-panel" id="catalogo-trofeus">
    <header class="rz-panel-head">
      <div><h2>Sistema automático de troféus</h2><p>Cada regra é verificada após as kills chegarem pelo FTP. O troféu entra no perfil sem depender do ADM.</p></div>
      <div class="rz-trophy-total"><strong><%= trophyCatalog.length %></strong><span>conquistas automáticas</span></div>
    </header>
    <div class="rz-trophy-filterbar" data-trophy-filters aria-label="Filtrar troféus">
      <button type="button" class="active" data-trophy-filter="ALL">Todos <b><%= trophyCatalog.length %></b></button>
      <% [['KILLS','Kills'],['PRECISION','Precisão'],['DISTANCE','Distância'],['SURVIVAL','KD'],['RIVALRY','Rivais'],['WEAPONS','Armas'],['LEGEND','Lendários']].forEach(([key,label]) => { %>
        <button type="button" data-trophy-filter="<%= key %>"><%= label %> <b><%= trophyCatalog.filter(t => t.category === key).length %></b></button>
      <% }) %>
    </div>
    <div class="rz-trophy-catalog" data-trophy-catalog>
      <% trophyCatalog.forEach((trophy, trophyIndex) => { %>
        <article style="--trophy:<%= trophy.color %>" data-trophy-category="<%= trophy.category %>">
          <span class="rz-trophy-number"><%= String(trophyIndex + 1).padStart(2, '0') %></span>
          <img loading="lazy" decoding="async" src="<%= trophy.imageUrl %>" alt="Troféu <%= trophy.title %>">
          <div><small><%= trophy.rarity || ('Nível ' + trophy.tier) %> • Nível <%= trophy.tier %> • +<%= trophy.points %> pontos</small><h3><%= trophy.title %></h3><p><%= trophy.description %></p><b><%= trophy.targetLabel %></b></div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="rz-stat-strip" aria-label="Resumo do ranking">
    <div><span>Kills</span><strong><%= coins(totals.kills) %></strong></div>
    <div><span>Players</span><strong><%= coins(totals.players) %></strong></div>
    <div><span>Headshots</span><strong><%= coins(totals.headshots) %></strong></div>
    <div><span>Maior distância</span><strong><%= Math.round(totals.longestKill || 0) %>m</strong></div>
  </section>
</main>

<script>
(() => {
  const bar = document.querySelector('[data-trophy-filters]');
  const catalog = document.querySelector('[data-trophy-catalog]');
  if (!bar || !catalog) return;
  const buttons = Array.from(bar.querySelectorAll('[data-trophy-filter]'));
  const cards = Array.from(catalog.querySelectorAll('[data-trophy-category]'));
  bar.addEventListener('click', (event) => {
    const button = event.target.closest('[data-trophy-filter]');
    if (!button) return;
    const filter = button.dataset.trophyFilter || 'ALL';
    buttons.forEach((item) => item.classList.toggle('active', item === button));
    cards.forEach((card) => {
      card.hidden = filter !== 'ALL' && card.dataset.trophyCategory !== filter;
    });
  });
})();
</script>

<%- include('partials/footer') %>
