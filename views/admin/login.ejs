<%- include('../partials/head') %>
<main class="container narrow admin-login">
  <%- include('../partials/alerts') %>
  <section class="card">
    <img src="/images/sz-logo-main.png" class="login-logo" alt="Logo">
    <h1>Painel Admin</h1>
    <form method="POST" action="/admin/login" class="form-grid">
      <label>Usuário
        <input name="user" value="admin" required>
      </label>
      <label>Senha
        <input name="password" type="password" required>
      </label>
      <button class="btn primary" type="submit">Entrar</button>
    </form>
  </section>
</main>
<%- include('../partials/footer') %>
