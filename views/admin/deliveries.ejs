<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="container">
  <%- include('_admin_nav') %>
  <%- include('../partials/alerts') %>
  <section class="card delivery-queue-card-v102">
    <h1>Fila de entrega DayZ</h1>
    <p class="muted">O site envia os PENDING por FTP. O mod lê somente arquivos locais, entrega e grava o resultado para o site ler pelo FTP.</p>
    <div class="delivery-table-scroll-v102" role="region" aria-label="Fila de entregas" tabindex="0">
    <table class="delivery-table-v102">
      <colgroup>
        <col class="delivery-col-date-v102">
        <col class="delivery-col-steam-v102">
        <col class="delivery-col-item-v102">
        <col class="delivery-col-class-v102">
        <col class="delivery-col-qty-v102">
        <col class="delivery-col-server-v102">
        <col class="delivery-col-status-v102">
        <col class="delivery-col-error-v102">
        <col class="delivery-col-action-v102">
      </colgroup>
      <thead><tr><th>Data</th><th>Steam64</th><th>Item</th><th>Classname</th><th>Qtd</th><th>Servidor</th><th>Status</th><th>Erro</th><th>Ação</th></tr></thead>
      <tbody>
        <% deliveries.forEach(d => { %>
          <tr>
            <td><%= dateTime(d.createdAt) %></td>
            <td><code><%= d.steam64 %></code></td>
            <td><%= d.productName %></td>
            <td><code><%= d.classname %></code></td>
            <td><%= d.quantity %></td>
            <td><%= d.serverType %></td>
            <td><span class="status <%= d.status.toLowerCase() %>"><%= d.status %></span></td>
            <td><small><%= d.error || '-' %></small></td>
            <td><form method="POST" action="/admin/deliveries/<%= d.id %>/reset"><button class="btn small">Reenviar</button></form></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    </div>
  </section>
</main>
<%- include('../partials/footer') %>
