<%- include('../partials/head') %>
<%- include('../partials/nav') %>
<main class="admin-shell-v46 admin-outfits-v49">
  <%- include('../partials/alerts') %>
  <%- include('_admin_nav') %>
  <style>
    .admin-outfits-v49 .admin-main-v49{min-width:0}.outfits-board-v49{display:grid;grid-template-columns:minmax(340px,440px) minmax(0,1fr);gap:18px}.outfit-form-v49,.outfit-list-panel-v49,.outfit-active-panel-v49{border:1px solid rgba(148,163,184,.16);border-radius:24px;background:linear-gradient(180deg,rgba(9,16,30,.90),rgba(3,7,14,.94));padding:18px;box-shadow:0 28px 80px rgba(0,0,0,.28)}.outfit-form-v49 label{display:grid;gap:7px;color:#dbe4f0;font-weight:850;margin-bottom:10px}.outfit-form-v49 input,.outfit-form-v49 textarea,.outfit-form-v49 select{width:100%;background:#050b16;border:1px solid rgba(148,163,184,.18);border-radius:12px;color:#fff;padding:12px}.outfit-form-v49 textarea{min-height:190px;font-family:ui-monospace,Consolas,monospace}.outfit-grid-admin-v49{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px}.outfit-admin-card-v49{display:grid;grid-template-columns:82px minmax(0,1fr);gap:12px;padding:12px;border:1px solid rgba(148,163,184,.14);border-radius:19px;background:rgba(15,23,42,.62)}.outfit-admin-card-v49 img{width:82px;height:82px;object-fit:contain;border-radius:15px;background:#050b16}.outfit-admin-card-v49 h3{margin:0}.outfit-admin-card-v49 p{margin:5px 0;color:#aeb8c8}.outfit-admin-card-v49 code{display:inline-block;margin:3px 3px 0 0;font-size:.7rem;background:rgba(255,255,255,.06);border-radius:8px;padding:4px 6px}.outfit-actions-admin-v49{display:flex;gap:7px;flex-wrap:wrap;margin-top:10px}.catalog-mini-v49{max-height:430px;overflow:auto;display:grid;gap:7px}.catalog-mini-v49 button{display:grid;grid-template-columns:42px 1fr auto;gap:8px;align-items:center;text-align:left;border:1px solid rgba(148,163,184,.13);background:rgba(15,23,42,.55);color:#fff;border-radius:12px;padding:7px;cursor:pointer}.catalog-mini-v49 img{width:42px;height:42px;object-fit:contain}.catalog-mini-v49 small{color:#9fb0c5}.outfit-split-v49{display:grid;grid-template-columns:1fr 340px;gap:14px}.active-subs-v49{display:grid;gap:8px;max-height:320px;overflow:auto}.active-subs-v49 div{padding:10px;border:1px solid rgba(148,163,184,.13);border-radius:12px;background:rgba(255,255,255,.04)}@media(max-width:1100px){.outfits-board-v49,.outfit-split-v49{grid-template-columns:1fr}}
  </style>
  <section class="admin-main-v49">
    <div class="admin-page-head-v46"><p class="eyebrow">Trajes / Assinaturas</p><h1>Trajes VIP mensais</h1><p class="muted">Configure quais types o player vai nascer no inventário enquanto a assinatura estiver ativa. O mod vai consultar a API quando o player renascer.</p></div>
    <div class="outfits-board-v49">
      <form class="outfit-form-v49" method="POST" action="<%= editing ? '/admin/outfits/' + editing.id : '/admin/outfits' %>" enctype="multipart/form-data">
        <h2><%= editing ? 'Editar traje' : 'Criar traje' %></h2>
        <label>Nome<input name="name" value="<%= editing?.name || '' %>" required></label>
        <div class="inline-grid two-cols"><label>Nível<input name="level" type="number" min="1" value="<%= editing?.level || 1 %>"></label><label>Preço RZ mensal<input name="priceCoins" type="number" min="0" value="<%= editing?.priceCoins || 0 %>"></label></div>
        <div class="inline-grid two-cols"><label>Dias<input name="durationDays" type="number" min="1" value="<%= editing?.durationDays || 30 %>"></label><label>Servidor<select name="serverType"><option value="vanilla" <%= editing?.serverType === 'vanilla' ? 'selected' : '' %>>Vanilla</option><option value="bbp" <%= editing?.serverType === 'bbp' ? 'selected' : '' %>>Vanilla+</option></select></label></div>
        <label>Descrição<textarea name="description"><%= editing?.description || '' %></textarea></label>
        <label>Imagem URL<input name="imageUrl" value="<%= editing?.imageUrl || '' %>" placeholder="https://... ou deixe vazio para buscar na Wiki pelo type"></label>
        <label>Upload imagem<input name="image" type="file" accept="image/*"></label>
        <label>Types do traje <small class="muted">Formato: slot|classname|quantidade|nome. Ex: inventory|BandageDressing|1|Bandagem</small><textarea id="outfitItemsTextV49" name="itemsText" required><%= editing ? outfitItemsToText(editing.items || []) : 'body|Hoodie_Black|1|Moletom\nlegs|Jeans_Black|1|Calça\nfeet|AthleticShoes_Black|1|Tênis\ninventory|BandageDressing|1|Bandagem\ninventory|BakedBeansCan|1|Comida\ninventory|KitchenKnife|1|Faca\ninventory|SodaCan_Pipsi|1|Bebida' %></textarea></label>
        <label class="check-row"><input name="active" type="checkbox" <%= !editing || editing.active ? 'checked' : '' %>><span>Ativo para venda</span></label>
        <label class="check-row"><input name="streamerRewardEnabled" type="checkbox" <%= editing?.streamerRewardEnabled ? 'checked' : '' %>><span>Pode ser escolhido no bônus de 7 dias por streamer</span></label>
        <button class="btn primary" type="submit"><%= editing ? 'Salvar traje' : 'Criar traje' %></button>
      </form>
      <section class="outfit-split-v49">
        <div class="outfit-list-panel-v49"><div class="admin-v47-panel-head"><div><p class="eyebrow">Cadastrados</p><h2>Trajes criados</h2></div><a class="btn" href="/admin/outfits">Novo</a></div><div class="outfit-grid-admin-v49"><% outfits.forEach(o => { const items = Array.isArray(o.items) ? o.items : []; %><article class="outfit-admin-card-v49"><img src="<%= o.imageData ? '/outfit-image/' + o.id : (o.imageUrl || '/images/no-real-image.svg') %>" onerror="this.src='/images/no-real-image.svg'"><div><h3><%= o.name %></h3><p>Nível <%= o.level %> • <%= coins(o.priceCoins) %> RZ • <%= o.durationDays %> dias</p><% items.slice(0,5).forEach(i => { %><code><%= i.classname %></code><% }) %><div class="outfit-actions-admin-v49"><a class="btn small primary" href="/admin/outfits?edit=<%= o.id %>">Editar</a><form method="POST" action="/admin/outfits/<%= o.id %>/toggle"><button class="btn small"><%= o.active ? 'Desativar' : 'Ativar' %></button></form></div></div></article><% }) %></div></div>
        <aside class="outfit-active-panel-v49"><h2>Teste / Ativos</h2><form method="POST" action="/admin/outfits/check-player" class="form-stack"><input name="steam64" maxlength="17" placeholder="Steam64 para consultar"><button class="btn">Consultar traje ativo</button></form><h3>Assinaturas ativas</h3><div class="active-subs-v49"><% activeSubs.forEach(s => { %><div><strong><%= s.player?.nickname || s.steam64 %></strong><br><small><%= s.outfitTemplate?.name %> • até <%= s.expiresAt.toLocaleDateString('pt-BR') %> • <%= s.source %></small></div><% }) %></div><h3>Catálogo rápido</h3><input id="catalogSearchOutfitV49" placeholder="Buscar type para adicionar..." style="width:100%;margin-bottom:8px"><div class="catalog-mini-v49" id="catalogOutfitV49"></div></aside>
      </section>
    </div>
  </section>
</main>
<script>
 const CATALOG_OUTFIT_V49 = <%- JSON.stringify(catalog || []).replace(/</g, '\\u003c') %>;
 function esc(v){return String(v||'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));}
 function renderOutfitCatalog(){const q=String(document.getElementById('catalogSearchOutfitV49')?.value||'').toLowerCase();const list=CATALOG_OUTFIT_V49.filter(i=>!q||[i.name,i.classname,i.category].join(' ').toLowerCase().includes(q)).slice(0,80);document.getElementById('catalogOutfitV49').innerHTML=list.map(i=>`<button type="button" data-cn="${esc(i.classname)}" data-name="${esc(i.name)}"><img loading="lazy" decoding="async" src="${esc(i.imageUrl)}" onerror="this.src='/images/no-real-image.svg'"><span><b>${esc(i.name)}</b><small>${esc(i.classname)}</small></span><em>+</em></button>`).join('');}
 document.getElementById('catalogSearchOutfitV49')?.addEventListener('input',renderOutfitCatalog);renderOutfitCatalog();
 document.addEventListener('click',ev=>{const b=ev.target.closest('[data-cn]');if(!b)return;const ta=document.getElementById('outfitItemsTextV49');ta.value+=(ta.value.trim()?'\n':'')+`inventory|${b.dataset.cn}|1|${b.dataset.name}`;ta.focus();});
</script>
<%- include('../partials/footer') %>
