# Servidor
NODE_ENV=production
PORT=3000
PUBLIC_URL=https://SEU-PROJETO.up.railway.app
APP_NAME=RAID-Z Store
COOKIE_SECRET=troque_por_uma_senha_grande_aleatoria
FTP_CONFIG_SECRET=outra_senha_grande_para_criptografar_a_senha_ftp

# Banco PostgreSQL do Railway
DATABASE_URL=postgresql://user:password@host:5432/railway

# Admin do site
ADMIN_PASSWORD=troque_essa_senha
ADMIN_USER=admin

# API legada do site/mod. Pode ficar vazia se não houver conexão HTTP com o mod.
# Com ela vazia, /api fica bloqueado e o site continua iniciando normalmente.
API_KEY=

# Mercado Pago Pix - use as credenciais de PRODUÇÃO da conta que receberá
MERCADOPAGO_ACCESS_TOKEN=APP_USR-SEU_TOKEN_DE_PRODUCAO
# Aplicação criada como Checkout Transparente > API de Orders
MERCADOPAGO_API_MODE=auto
MERCADOPAGO_WEBHOOK_SECRET=
# Use e-mail real/válido; não use domínio .local
DEFAULT_PAYER_EMAIL=seu-email-real@exemplo.com

# Discord - use Webhook do canal de logs
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_NAME=RAID-Z Store
DISCORD_WEBHOOK_AVATAR_URL=

# Loja
STORE_CURRENCY_NAME=RZ Coins
MONTHLY_REPORT_CRON=0 9 1 * *
TIMEZONE=America/Sao_Paulo

# Discord separados - coloque os webhooks no Railway, não precisa mexer no código
DISCORD_SALES_WEBHOOK_URL=
DISCORD_RANKING_PLAYERS_VANILLA_WEBHOOK_URL=
DISCORD_RANKING_CLANS_VANILLA_WEBHOOK_URL=
DISCORD_RANKING_PLAYERS_BBP_WEBHOOK_URL=
DISCORD_RANKING_CLANS_BBP_WEBHOOK_URL=
DISCORD_RANKING_PLAYERS_GLOBAL_WEBHOOK_URL=
DISCORD_RANKING_CLANS_GLOBAL_WEBHOOK_URL=
DISCORD_RANKING_LANDS_WEBHOOK_URL=

# Segurança de atualização/deploy
# Deixe assim para atualização normal NÃO apagar dados dos players.
# O site preserva saldos, compras, entregas, garagem, seguros usados e dados de streamer.
ALLOW_DESTRUCTIVE_MIGRATIONS=false
SEED_OVERWRITE_EXISTING_PRODUCTS=false
SEED_OVERWRITE_EXISTING_VEHICLES=false
SEED_OVERWRITE_EXISTING_SETTINGS=false
SEED_OVERWRITE_EXISTING_PACKAGES=false
SEED_OVERWRITE_EXISTING_INSURANCE_PLANS=false
